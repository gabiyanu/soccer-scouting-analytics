# ── Gemini AI ────────────────────────────────────────────────────────────────
# Required for AI scouting reports. Injected automatically in AI Studio.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── BigQuery ──────────────────────────────────────────────────────────────────
# Google Cloud project that owns the BigQuery dataset.
BIGQUERY_PROJECT_ID=player-profiles-analyzer

# Dataset and table containing player profiles.
BIGQUERY_DATASET=Player_Analyzer
BIGQUERY_TABLE=Player_profiles

# Path to a service account JSON key file (local development).
# On Cloud Run / GCP, Application Default Credentials are used automatically —
# leave this unset and grant the Cloud Run service account BigQuery Data Viewer.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Port for the Express API server (default: 3001).
# API_PORT=3001

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL="MY_APP_URL"
